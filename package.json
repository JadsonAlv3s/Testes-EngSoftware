{
  "name": "testes-eng-software",
  "version": "1.0.0",
  "description": "Suíte de testes para a API LegendaViva: API, E2E (Playwright) e Performance (k6)",
  "scripts": {
    "test:api": "jest --config jest.config.js --testPathPattern=tests/api",
    "test:e2e": "npx playwright test",
    "test:performance": "k6 run tests/performance/load-test.js",
    "test:stress": "k6 run tests/performance/stress-test.js",
    "test:all": "npm run test:api && npx playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
