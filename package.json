{
  "name": "testes-eng-software",
  "version": "1.0.0",
  "description": "Suíte de testes completa: API, E2E (Playwright) e Performance (k6)",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test:api": "jest --config jest.config.js --testPathPattern=tests/api",
    "test:e2e": "npx playwright test",
    "test:performance": "k6 run tests/performance/load-test.js",
    "test:all": "npm run test:api && npx playwright test",
    "lint": "eslint src/ tests/"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-validator": "^7.0.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
